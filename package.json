{
  "name": "aifinpay-polygon",
  "version": "1.0.0",
  "description": "AiFinPay Polygon Smart Contracts",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "hardhat test",
    "build": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network amoy",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:sol": "prettier --write 'contracts/**/*.sol'",
    "lint:check": "prettier --check 'contracts/**/*.sol'"
  },
  "keywords": [
    "aifinpay",
    "polygon",
    "solidity",
    "erc20",
    "erc721"
  ],
  "author": "AiFinPay",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^17.4.2",
    "hardhat": "^2.22.19",
    "prettier": "^3.8.3",
    "prettier-plugin-solidity": "^2.3.1",
    "solhint": "^6.2.1",
    "typescript": "^5.7.3"
  }
}
