{
  "name": "aifinpay-polygon",
  "version": "1.0.0",
  "description": "AiFinPay Polygon Smart Contracts",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.ts --network polygon",
